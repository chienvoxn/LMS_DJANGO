SECRET_KEY= #Project secret key, you can generate one using `python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'`

DEBUG= # True or False, set to True for development and False for production

ALLOWED_HOSTS= # Comma-separated list of allowed hosts, e.g., localhost, ip-address, domain.com

# Database configuration

DB_NAME= # database name for your Django application
DB_USER= # database user for your Django application
DB_PASSWORD= # database password for your Django application
DB_HOST= # database host for your Django application
DB_PORT= # database port for your Django application

CORS_ALLOWED_ORIGINS= # Ip addresses or domains allowed to make cross-origin requests, e.g., http://localhost:3000,http://frontend-domain.com